#!/usr/bin/env python3
"""List frames or serve a specific frame (via ?name=...)."""
import base64
import json
import os
import sys

root = os.environ["PIPELINE_ROOT"]
frames_root = os.path.join(root, "output", "frames")
frame_dirs = [
    os.path.join(frames_root, "text"),
    os.path.join(frames_root, "diagrams"),
    os.path.join(frames_root, "diagrams_diag1"),
    os.path.join(frames_root, "diagrams_diag2"),
    frames_root,  # backward compatibility
]
name = os.environ.get("QUERY_NAME", "")

if name:
    safe_name = os.path.basename(name)
    path = ""
    for directory in frame_dirs:
        candidate = os.path.join(directory, safe_name)
        if os.path.isfile(candidate):
            path = candidate
            break
    if not path:
        sys.stdout.write("Status: 404\n\n")
        sys.stdout.write(json.dumps({"error": "frame not found"}))
        raise SystemExit(0)
    with open(path, "rb") as f:
        data = base64.b64encode(f.read()).decode()
    sys.stdout.write("\n")
    sys.stdout.write(json.dumps({"name": safe_name, "data": data, "mime": "image/png"}))
else:
    frames = []
    seen = set()
    for directory in frame_dirs:
        if os.path.isdir(directory):
            for f in sorted(os.listdir(directory)):
                if not f.endswith(".png"):
                    continue
                if f in seen:
                    continue
                seen.add(f)
                frames.append({"name": f, "size": os.path.getsize(os.path.join(directory, f))})
    sys.stdout.write("\n")
    sys.stdout.write(json.dumps({"frames": frames}))
