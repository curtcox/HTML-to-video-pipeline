#!/usr/bin/env python3
"""Clear pipeline outputs."""
import json
import os
import shutil
import sys

root = os.environ["PIPELINE_ROOT"]
output_dir = os.path.join(root, "output")

request_body = sys.stdin.buffer.read()
try:
    params = json.loads(request_body) if request_body else {}
except json.JSONDecodeError:
    params = {}

targets = params.get("targets", ["all"])
cleared = []

removals = {
    "frames":   ("dir",  os.path.join(output_dir, "frames")),
    "qr_codes": ("dir",  os.path.join(output_dir, "qr_codes")),
    "audio":    ("dir",  os.path.join(output_dir, "audio")),
    "captions": ("file", os.path.join(output_dir, "captions.srt")),
    "segments": ("file", os.path.join(output_dir, "segments.json")),
    "diagram_specs": ("file", os.path.join(output_dir, "diagram_specs.json")),
    "diagram_specs_diag1": ("file", os.path.join(output_dir, "diagram_specs_diag1.json")),
    "diagram_specs_diag2": ("file", os.path.join(output_dir, "diagram_specs_diag2.json")),
    "diagram_specs_text": ("file", os.path.join(output_dir, "diagram_specs.txt")),
    "diagram_specs_diag1_text": ("file", os.path.join(output_dir, "diagram_specs_diag1.txt")),
    "diagram_specs_diag2_text": ("file", os.path.join(output_dir, "diagram_specs_diag2.txt")),
    "diagram_frames_meta": ("file", os.path.join(output_dir, "diagram_frames.json")),
    "diagram_frames_diag1_meta": ("file", os.path.join(output_dir, "diagram_frames_diag1.json")),
    "diagram_frames_diag2_meta": ("file", os.path.join(output_dir, "diagram_frames_diag2.json")),
    "video_outputs_meta": ("file", os.path.join(output_dir, "video_outputs.json")),
    "video":    ("file", os.path.join(output_dir, "video.mp4")),
    "video_text": ("file", os.path.join(output_dir, "video_text.mp4")),
    "video_diagrams": ("file", os.path.join(output_dir, "video_diagrams.mp4")),
    "video_combined": ("file", os.path.join(output_dir, "video_combined.mp4")),
    "raw_video_text": ("file", os.path.join(output_dir, "raw_video_text.mp4")),
    "raw_video_diagrams": ("file", os.path.join(output_dir, "raw_video_diagrams.mp4")),
    "raw_video_diagrams_h": ("file", os.path.join(output_dir, "raw_video_diagrams_h.mp4")),
    "raw_video_diagrams_d1": ("file", os.path.join(output_dir, "raw_video_diagrams_d1.mp4")),
    "raw_video_diagrams_d2": ("file", os.path.join(output_dir, "raw_video_diagrams_d2.mp4")),
    "raw_video_combined": ("file", os.path.join(output_dir, "raw_video_combined.mp4")),
    "diagram_blank": ("file", os.path.join(output_dir, "diagram_blank.png")),
}

for name, (kind, path) in removals.items():
    if "all" not in targets and name not in targets:
        continue
    if kind == "dir" and os.path.isdir(path):
        shutil.rmtree(path)
        cleared.append(name)
    elif kind == "file" and os.path.exists(path):
        os.remove(path)
        cleared.append(name)

sys.stdout.write("\n")
sys.stdout.write(json.dumps({"status": "ok", "cleared": cleared}))
