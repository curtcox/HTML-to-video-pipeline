#!/usr/bin/env python3
"""Run the QR code generation stage."""
import json
import os
import sys

from webapp.route_io import redirect_stdout_to_stderr

root = os.environ["PIPELINE_ROOT"]
output_dir = os.path.join(root, "output")
segments_path = os.path.join(output_dir, "segments.json")

if not os.path.exists(segments_path):
    sys.stdout.write("Status: 400\n\n")
    sys.stdout.write(json.dumps({"error": "No segments.json found. Run parse stage first."}))
    raise SystemExit(0)

try:
    with redirect_stdout_to_stderr():
        from parse_article import segments_from_json, get_all_citation_urls
        from generate_qr import generate_all_qr_codes

        segments = segments_from_json(segments_path)
        citation_urls = get_all_citation_urls(segments)
        qr_dir = os.path.join(output_dir, "qr_codes")
        os.makedirs(qr_dir, exist_ok=True)

        # Returns dict: url -> qr_image_path
        qr_map = generate_all_qr_codes(citation_urls, qr_dir)

        # Persist so visuals stage can overlay QR codes
        with open(os.path.join(output_dir, "qr_map.json"), "w") as f:
            json.dump(qr_map, f, indent=2)

    body = json.dumps({
        "status": "ok",
        "qr_count": len(qr_map),
        "citation_count": len(citation_urls),
    })
except Exception as e:
    import traceback
    sys.stdout.write("Status: 500\n\n")
    sys.stdout.write(json.dumps({"error": str(e), "traceback": traceback.format_exc()}))
    raise SystemExit(0)

sys.stdout.write(body)
