#!/usr/bin/env python3
"""Run the visual frame generation stage."""
from dataclasses import asdict
import json
import os
import sys

from webapp.route_io import redirect_stdout_to_stderr

root = os.environ["PIPELINE_ROOT"]
output_dir = os.path.join(root, "output")
segments_path = os.path.join(output_dir, "segments.json")

if not os.path.exists(segments_path):
    sys.stdout.write("Status: 400\n\n")
    sys.stdout.write(json.dumps({"error": "No segments.json found. Run parse stage first."}))
    raise SystemExit(0)

try:
    with redirect_stdout_to_stderr():
        from diagram_specs import resolved_specs_from_json
        from config import PipelineConfig
        from parse_article import segments_from_json
        from generate_visuals import generate_frames_for_segments, generate_diagram_track_frames

        segments = segments_from_json(segments_path)
        config = PipelineConfig(output_dir=output_dir)
        frames_root = os.path.join(output_dir, "frames")
        text_frames_dir = os.path.join(frames_root, "text")
        diagram_frames_dir = os.path.join(frames_root, "diagrams")
        diagram_diag1_frames_dir = os.path.join(frames_root, "diagrams_diag1")
        diagram_diag2_frames_dir = os.path.join(frames_root, "diagrams_diag2")
        os.makedirs(text_frames_dir, exist_ok=True)
        os.makedirs(diagram_frames_dir, exist_ok=True)
        os.makedirs(diagram_diag1_frames_dir, exist_ok=True)
        os.makedirs(diagram_diag2_frames_dir, exist_ok=True)
        for directory in (
            text_frames_dir,
            diagram_frames_dir,
            diagram_diag1_frames_dir,
            diagram_diag2_frames_dir,
        ):
            for name in os.listdir(directory):
                if name.endswith(".png"):
                    os.remove(os.path.join(directory, name))

        # Load qr_map if QR stage has run
        qr_map_path = os.path.join(output_dir, "qr_map.json")
        if os.path.exists(qr_map_path):
            with open(qr_map_path) as f:
                qr_map = json.load(f)
        else:
            qr_map = {}

        diagram_specs_path = os.path.join(output_dir, "diagram_specs.json")
        if os.path.exists(diagram_specs_path):
            resolved_diagrams = resolved_specs_from_json(diagram_specs_path)
        else:
            resolved_diagrams = []
        diagram_specs_diag1_path = os.path.join(output_dir, "diagram_specs_diag1.json")
        if os.path.exists(diagram_specs_diag1_path):
            resolved_diagrams_diag1 = resolved_specs_from_json(diagram_specs_diag1_path)
        else:
            resolved_diagrams_diag1 = []
        diagram_specs_diag2_path = os.path.join(output_dir, "diagram_specs_diag2.json")
        if os.path.exists(diagram_specs_diag2_path):
            resolved_diagrams_diag2 = resolved_specs_from_json(diagram_specs_diag2_path)
        else:
            resolved_diagrams_diag2 = []

        frames = generate_frames_for_segments(segments, qr_map, config, text_frames_dir)
        diagram_frames = generate_diagram_track_frames(
            resolved_diagrams,
            qr_map,
            config,
            diagram_frames_dir,
            frame_name_prefix="diagram_overlay_h",
        )
        diagram_frames_diag1 = generate_diagram_track_frames(
            resolved_diagrams_diag1,
            qr_map,
            config,
            diagram_diag1_frames_dir,
            frame_name_prefix="diagram_overlay_d1",
        )
        diagram_frames_diag2 = generate_diagram_track_frames(
            resolved_diagrams_diag2,
            qr_map,
            config,
            diagram_diag2_frames_dir,
            frame_name_prefix="diagram_overlay_d2",
        )
        with open(os.path.join(output_dir, "frames.json"), "w") as f:
            json.dump([asdict(frame) for frame in frames], f, indent=2)
        with open(os.path.join(output_dir, "diagram_frames.json"), "w") as f:
            json.dump([asdict(frame) for frame in diagram_frames], f, indent=2)
        with open(os.path.join(output_dir, "diagram_frames_diag1.json"), "w") as f:
            json.dump([asdict(frame) for frame in diagram_frames_diag1], f, indent=2)
        with open(os.path.join(output_dir, "diagram_frames_diag2.json"), "w") as f:
            json.dump([asdict(frame) for frame in diagram_frames_diag2], f, indent=2)
    body = json.dumps({
        "status": "ok",
        "text_frame_count": len(frames),
        "diagram_frame_count": len(diagram_frames) + len(diagram_frames_diag1) + len(diagram_frames_diag2),
        "diagram_frame_count_horizontal": len(diagram_frames),
        "diagram_frame_count_diagonal_1": len(diagram_frames_diag1),
        "diagram_frame_count_diagonal_2": len(diagram_frames_diag2),
    })
except Exception as e:
    import traceback
    sys.stdout.write("Status: 500\n\n")
    sys.stdout.write(json.dumps({"error": str(e), "traceback": traceback.format_exc()}))
    raise SystemExit(0)

sys.stdout.write(body)
