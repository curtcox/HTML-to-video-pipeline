#!/usr/bin/env python3
"""Run the parse stage: fetch article HTML and extract segments."""
import json
import os
import sys

root = os.environ["PIPELINE_ROOT"]
output_dir = os.path.join(root, "output")
os.makedirs(output_dir, exist_ok=True)

request_body = sys.stdin.buffer.read()
try:
    params = json.loads(request_body) if request_body else {}
except json.JSONDecodeError:
    params = {}

url = params.get("url", "")
segments_json_path = params.get("segments_json", "")
diagram_specs_text = params.get("diagram_specs_text", params.get("diagram_specs", ""))
diagram_specs_file = params.get("diagram_specs_file", "")
diagram_specs_diag1_text = params.get("diagram_specs_diag1_text", "")
diagram_specs_diag1_file = params.get("diagram_specs_diag1_file", "")
diagram_specs_diag2_text = params.get("diagram_specs_diag2_text", "")
diagram_specs_diag2_file = params.get("diagram_specs_diag2_file", "")
overlap_resolution = params.get("overlap_resolution", "manual")

try:
    from diagram_specs import (
        parse_diagram_specs_text,
        load_diagram_specs_text,
        resolve_diagram_specs,
        find_overlapping_resolved_diagrams,
        auto_adjust_overlapping_resolved_diagrams,
        overlap_error_message,
        resolved_specs_to_json,
    )
    from parse_article import fetch_html, parse_article, segments_to_json, get_all_citation_urls, segments_from_json

    if segments_json_path:
        segments = segments_from_json(segments_json_path)
    elif url:
        html = fetch_html(url)
        segments = parse_article(html)
    else:
        import build_segments as bs
        segments_path = os.path.join(output_dir, "segments.json")
        with open(segments_path, "w") as f:
            json.dump(bs.segments, f, indent=2)
        segments = segments_from_json(segments_path)

    segments_path = os.path.join(output_dir, "segments.json")
    with open(segments_path, "w") as f:
        f.write(segments_to_json(segments))

    def resolve_track(track_name: str, raw_text: str, source_file: str):
        text_value = raw_text
        if source_file:
            text_value = load_diagram_specs_text(source_file)
        specs = parse_diagram_specs_text(text_value) if text_value.strip() else []
        resolved = resolve_diagram_specs(specs, segments, allow_overlaps=True) if specs else []
        overlaps = find_overlapping_resolved_diagrams(resolved)
        adjustments = []
        if overlaps:
            if overlap_resolution == "auto_shrink":
                resolved, adjustments, remaining_manual = auto_adjust_overlapping_resolved_diagrams(resolved)
                if remaining_manual:
                    raise ValueError(
                        f"{track_name}: "
                        + overlap_error_message(remaining_manual, manual_required_pairs=remaining_manual)
                    )
                overlaps = find_overlapping_resolved_diagrams(resolved)
                if overlaps:
                    raise ValueError(f"{track_name}: " + overlap_error_message(overlaps, manual_required_pairs=overlaps))
            else:
                raise ValueError(f"{track_name}: " + overlap_error_message(overlaps))
        return text_value, resolved, adjustments

    horizontal_text, resolved_diagrams, overlap_adjustments_h = resolve_track(
        "horizontal diagrams",
        diagram_specs_text,
        diagram_specs_file,
    )
    diag1_text, resolved_diagrams_diag1, overlap_adjustments_d1 = resolve_track(
        "diagonal-1 diagrams",
        diagram_specs_diag1_text,
        diagram_specs_diag1_file,
    )
    diag2_text, resolved_diagrams_diag2, overlap_adjustments_d2 = resolve_track(
        "diagonal-2 diagrams",
        diagram_specs_diag2_text,
        diagram_specs_diag2_file,
    )

    with open(os.path.join(output_dir, "diagram_specs.txt"), "w", encoding="utf-8") as f:
        f.write(horizontal_text or "")
    with open(os.path.join(output_dir, "diagram_specs_diag1.txt"), "w", encoding="utf-8") as f:
        f.write(diag1_text or "")
    with open(os.path.join(output_dir, "diagram_specs_diag2.txt"), "w", encoding="utf-8") as f:
        f.write(diag2_text or "")

    with open(os.path.join(output_dir, "diagram_specs.json"), "w", encoding="utf-8") as f:
        f.write(resolved_specs_to_json(resolved_diagrams))
    with open(os.path.join(output_dir, "diagram_specs_diag1.json"), "w", encoding="utf-8") as f:
        f.write(resolved_specs_to_json(resolved_diagrams_diag1))
    with open(os.path.join(output_dir, "diagram_specs_diag2.json"), "w", encoding="utf-8") as f:
        f.write(resolved_specs_to_json(resolved_diagrams_diag2))

    citations = get_all_citation_urls(segments)
    total_diagrams = len(resolved_diagrams) + len(resolved_diagrams_diag1) + len(resolved_diagrams_diag2)
    total_adjustments = len(overlap_adjustments_h) + len(overlap_adjustments_d1) + len(overlap_adjustments_d2)
    body = json.dumps({
        "status": "ok",
        "segment_count": len(segments),
        "citation_count": len(citations),
        "diagram_count": total_diagrams,
        "diagram_count_horizontal": len(resolved_diagrams),
        "diagram_count_diagonal_1": len(resolved_diagrams_diag1),
        "diagram_count_diagonal_2": len(resolved_diagrams_diag2),
        "overlap_adjustment_count": total_adjustments,
    })
except Exception as e:
    sys.stdout.write("Status: 500\n\n")
    sys.stdout.write(json.dumps({"error": str(e)}))
    raise SystemExit(0)

sys.stdout.write("\n")
sys.stdout.write(body)
