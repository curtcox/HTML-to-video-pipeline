<script>
const log = document.getElementById('log');
let audioNames = [];
let videoVariants = {};

function activateOutputTab(tabName) {
  document.querySelectorAll('.tab-btn').forEach((btn) => btn.classList.remove('active'));
  document.querySelectorAll('.tab-panel').forEach((panel) => panel.classList.remove('active'));
  const btn = document.getElementById(`tab-btn-${tabName}`);
  const panel = document.getElementById(`panel-${tabName}`);
  if (btn) btn.classList.add('active');
  if (panel) panel.classList.add('active');
}

function activateSpecTab(tabName) {
  document.querySelectorAll('.spec-tab-btn').forEach((btn) => btn.classList.remove('active'));
  document.querySelectorAll('.spec-tab-panel').forEach((panel) => panel.classList.remove('active'));
  const btn = document.getElementById(`spec-tab-btn-${tabName}`);
  const panel = document.getElementById(`spec-tab-${tabName}`);
  if (btn) btn.classList.add('active');
  if (panel) panel.classList.add('active');
}

function addLog(msg, cls = 'info') {
  const ts = new Date().toLocaleTimeString();
  log.innerHTML += `<span class="${cls}">[${ts}] ${msg}</span>\n`;
  log.scrollTop = log.scrollHeight;
}

async function api(method, path, body) {
  const opts = { method };
  if (body) {
    opts.headers = { 'Content-Type': 'application/json' };
    opts.body = JSON.stringify(body);
  }
  const res = await fetch(path, opts);
  return res.json();
}

function setStageStatus(stage, text, state) {
  const btn = document.querySelector(`[data-stage="${stage}"]`);
  document.getElementById(`status-${stage}`).textContent = text;
  btn.className = 'stage-btn' + (state ? ` ${state}` : '');
}

function closeLightbox() {
  const audio = document.getElementById('lightbox-audio');
  audio.pause();
  audio.removeAttribute('src');
  audio.load();
  document.getElementById('lightbox').classList.remove('open');
}

document.addEventListener('keydown', (event) => {
  if (event.key === 'Escape') closeLightbox();
});

function findMatchingAudio(frameName) {
  const match = frameName.match(/_(\d+)\.png$/);
  if (!match) return null;
  const index = match[1];
  return audioNames.find(name => name === `audio_${index}.wav`) ||
         audioNames.find(name => name === `audio_${index}.mp3`) ||
         null;
}

function openFramePreview(imageSrc, frameName) {
  const lightbox = document.getElementById('lightbox');
  const img = document.getElementById('lightbox-img');
  const audio = document.getElementById('lightbox-audio');
  const meta = document.getElementById('lightbox-meta');
  img.src = imageSrc;
  img.alt = frameName;

  const audioName = findMatchingAudio(frameName);
  if (audioName) {
    audio.src = `/api/outputs/audio?name=${encodeURIComponent(audioName)}`;
    audio.style.display = '';
    meta.textContent = `${frameName} with ${audioName}`;
  } else {
    audio.pause();
    audio.removeAttribute('src');
    audio.load();
    audio.style.display = 'none';
    meta.textContent = `${frameName} (no matching audio clip)`;
  }

  lightbox.classList.add('open');
}

function selectVideoVariant() {
  const selector = document.getElementById('video-variant');
  const key = selector.value;
  const filename = videoVariants[key];
  if (!filename) return;
  const url = `/api/outputs/video?name=${encodeURIComponent(filename)}`;
  const player = document.getElementById('video-player');
  const dl = document.getElementById('video-download');
  player.src = url;
  dl.href = url;
  dl.download = filename;
}

async function runStage(stage) {
  setStageStatus(stage, 'Running...', 'running');
  addLog(`Starting ${stage}...`);
  let body = {};
  if (stage === 'parse') {
    const url = document.getElementById('url-input').value;
    if (url) body.url = url;
    body.diagram_specs_text = document.getElementById('diagram-specs').value || '';
    body.diagram_specs_diag1_text = document.getElementById('diagram-specs-diag1').value || '';
    body.diagram_specs_diag2_text = document.getElementById('diagram-specs-diag2').value || '';
  }
  if (stage === 'audio') {
    body.dry_run = false;
    body.provider = document.getElementById('tts-provider').value;
  }
  if (stage === 'assemble') {
    const mode = document.getElementById('assemble-mode').value || 'combined';
    if (mode === 'all') body.video_modes = ['text', 'diagrams', 'combined'];
    else body.video_modes = [mode];
  }

  const runOnce = async (payload) => api('POST', `/api/stages/${stage}`, payload);

  try {
    let data = await runOnce(body);
    if (
      stage === 'parse' &&
      data.error &&
      data.error.includes('Overlapping diagram intervals detected') &&
      !body.overlap_resolution
    ) {
      const autoFix = confirm(
        'Diagram overlaps were detected. Auto-adjust start/stop ranges to remove overlap when possible?\n\n' +
        'Note: diagrams with identical start and stop ranges must be changed manually.'
      );
      if (autoFix) {
        addLog('parse overlap detected: attempting automatic overlap reduction...', 'warn');
        data = await runOnce({ ...body, overlap_resolution: 'auto_shrink' });
      }
    }

    if (data.error) {
      setStageStatus(stage, 'Error', '');
      addLog(`${stage} error: ${data.error}`, 'err');
      return false;
    } else {
      const info = Object.entries(data).filter(([k]) => k !== 'status').map(([k,v]) => `${k}=${v}`).join(', ');
      setStageStatus(stage, 'Done', 'done');
      addLog(`${stage} complete: ${info}`, 'ok');
      refreshOutputs();
      return true;
    }
  } catch (e) {
    setStageStatus(stage, 'Error', '');
    addLog(`${stage} failed: ${e.message}`, 'err');
    return false;
  }
}

async function runAll() {
  for (const s of ['parse', 'qr', 'visuals', 'audio', 'captions', 'assemble']) {
    const ok = await runStage(s);
    if (!ok) {
      addLog(`Run stopped after ${s} failed.`, 'warn');
      break;
    }
  }
}

async function refreshOutputs() {
  try {
    const data = await api('GET', '/api/outputs');
    audioNames = (data.audio || []).map(a => a.name);
    const warningBox = document.getElementById('sync-warning');
    if (data.sync_report && data.sync_report.warnings && data.sync_report.warnings.length > 0) {
      const report = data.sync_report;
      warningBox.classList.add('open');
      warningBox.innerHTML = `
        <strong>Sync warning</strong><br>
        Audio ${report.combined_audio_duration.toFixed(3)}s, frame sequence ${report.frame_sequence_duration.toFixed(3)}s, clip plan ${report.clip_plan_duration.toFixed(3)}s, raw video ${report.raw_video_duration.toFixed(3)}s, final video ${report.final_video_duration.toFixed(3)}s.<br>
        ${report.warnings.map(w => w.replace(/</g, '&lt;')).join('<br>')}
      `;
    } else {
      warningBox.classList.remove('open');
      warningBox.textContent = '';
    }
    const textFrames = data.frames || [];
    const diagramFrames = data.diagram_frames || [];

    document.getElementById('count-frames').textContent = textFrames.length;
    const gallery = document.getElementById('gallery-frames');
    gallery.innerHTML = '';
    for (const frame of textFrames.slice(0, 50)) {
      const imgData = await api('GET', `/api/outputs/frames?name=${encodeURIComponent(frame.name)}`);
      if (imgData.data) {
        const img = document.createElement('img');
        img.src = `data:image/png;base64,${imgData.data}`;
        img.title = frame.name;
        img.onclick = (e) => { e.stopPropagation(); openFramePreview(img.src, frame.name); };
        gallery.appendChild(img);
      }
    }
    if (textFrames.length === 0) {
      gallery.innerHTML = '<div class="empty-note">No text frames yet</div>';
    }

    document.getElementById('count-diagram-frames').textContent = diagramFrames.length;
    const diagramGallery = document.getElementById('gallery-diagram-frames');
    diagramGallery.innerHTML = '';
    for (const frame of diagramFrames.slice(0, 50)) {
      const imgData = await api('GET', `/api/outputs/frames?name=${encodeURIComponent(frame.name)}`);
      if (imgData.data) {
        const img = document.createElement('img');
        img.src = `data:image/png;base64,${imgData.data}`;
        img.title = frame.name;
        img.onclick = (e) => { e.stopPropagation(); openFramePreview(img.src, frame.name); };
        diagramGallery.appendChild(img);
      }
    }
    if (diagramFrames.length === 0) {
      diagramGallery.innerHTML = '<div class="empty-note">No diagram frames yet</div>';
    }

    document.getElementById('count-qr').textContent = data.qr_codes ? data.qr_codes.length : 0;
    const qrGallery = document.getElementById('gallery-qr');
    qrGallery.innerHTML = '';
    for (const qr of (data.qr_codes || []).slice(0, 50)) {
      const imgData = await api('GET', `/api/outputs/qr?name=${encodeURIComponent(qr.name)}`);
      if (imgData.data) {
        const img = document.createElement('img');
        img.src = `data:image/png;base64,${imgData.data}`;
        img.title = qr.name;
        img.style.maxWidth = '120px';
        img.onclick = (e) => {
          e.stopPropagation();
          document.getElementById('lightbox-img').src = img.src;
          document.getElementById('lightbox-img').alt = qr.name;
          document.getElementById('lightbox-audio').pause();
          document.getElementById('lightbox-audio').removeAttribute('src');
          document.getElementById('lightbox-audio').load();
          document.getElementById('lightbox-audio').style.display = 'none';
